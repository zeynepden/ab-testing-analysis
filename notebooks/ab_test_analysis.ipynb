{
 "cells": [
  {
   "cell_type": "markdown",
   "source": [
    "# A/B Testing Analysis\n",
    "This project analyzes whether a new landing page improves conversion rate."
   ]
  },
  {
   "cell_type": "markdown",
   "source": [
    "## Import Libraries"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from statsmodels.stats.proportion import proportions_ztest"
   ]
  },
  {
   "cell_type": "markdown",
   "source": [
    "## Load Dataset"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "df = pd.read_csv('../data/ab_test_data.csv')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "source": [
    "## Conversion Rates"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "conversion_rates = df.groupby('group')['converted'].mean()\n",
    "conversion_rates"
   ]
  },
  {
   "cell_type": "markdown",
   "source": [
    "## Visualization"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "conversion_rates.plot(kind='bar')\n",
    "plt.title('Conversion Rate by Group')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "source": [
    "## Statistical Test"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "counts = df.groupby('group')['converted'].sum()\n",
    "nobs = df.groupby('group')['converted'].count()\n",
    "\n",
    "z_stat, p_value = proportions_ztest(count=counts, nobs=nobs)\n",
    "\n",
    "print('Z-statistic:', z_stat)\n",
    "print('P-value:', p_value)"
   ]
  }
 ]
}
